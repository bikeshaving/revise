{
  "name": "@b9g/revise",
  "version": "0.1.3",
  "private": true,
  "license": "MIT",
  "type": "module",
  "main": "./dist/src/contentarea.js",
  "exports": {
    "./edit.js": {
      "types": "./dist/src/edit.d.ts",
      "import": "./dist/src/edit.js",
      "require": "./dist/src/edit.cjs"
    },
    "./contentarea.js": {
      "types": "./dist/src/contentarea.d.ts",
      "import": "./dist/src/contentarea.js",
      "require": "./dist/src/contentarea.cjs"
    },
    "./keyer.js": {
      "types": "./dist/src/keyer.d.ts",
      "import": "./dist/src/keyer.js",
      "require": "./dist/src/keyer.cjs"
    },
    "./history.js": {
      "types": "./dist/src/history.d.ts",
      "import": "./dist/src/history.js",
      "require": "./dist/src/history.cjs"
    },
    "./state.js": {
      "types": "./dist/src/state.d.ts",
      "import": "./dist/src/state.js",
      "require": "./dist/src/state.cjs"
    }
  },
  "scripts": {
    "build": "libuild build",
    "publish": "libuild publish",
    "test": "playwright-test --runner uvu",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "echo 'ERROR: Cannot publish from root directory. Use libuild publish instead.' && exit 1"
  },
  "devDependencies": {
    "@b9g/libuild": "file:../libuild",
    "playwright-test": "^8.1.1",
    "typescript": "^5.0.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
